{
  "name": "rootpilot",
  "version": "0.1.0",
  "private": true,
  "description": "OpenTelemetry-native observability platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "test": "vitest run",
    "lint": "eslint . --ext .ts,.tsx,.cjs && prettier --check .",
    "db:init": "npm run db:init --workspace=apps/api",
    "seed": "npm run seed --workspace=apps/api"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
