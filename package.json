{
  "name": "rootpilot",
  "version": "0.1.0",
  "private": true,
  "description": "OpenTelemetry-native observability platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "test": "vitest run",
    "lint": "eslint . --ext .ts,.tsx,.cjs && prettier --check .",
    "db:init": "npm run db:init --workspace=apps/api",
    "db:migrate": "npm run db:migrate --workspace=apps/api",
    "seed": "npm run seed --workspace=apps/api",
    "graph:build": "npm run graph:build --workspace=apps/api --",
    "error-groups:build": "npm run error-groups:build --workspace=apps/api --",
    "deployments:analyze": "npm run deployments:analyze --workspace=apps/api --",
    "correlations:refresh": "npm run correlations:refresh --workspace=apps/api --",
    "simulate": "npm run simulate --workspace=apps/simulator --",
    "simulate:graph": "npm run simulate -- --scenario multi-service --duration 10m --rate 40",
    "simulate:normal": "npm run simulate -- --scenario normal",
    "simulate:bad-deploy": "npm run simulate -- --scenario bad-deploy",
    "simulate:checkout-error": "npm run simulate -- --scenario checkout-error",
    "simulate:database": "npm run simulate -- --scenario database-degradation",
    "simulate:cache": "npm run simulate -- --scenario cache-miss-storm",
    "simulate:dry-run": "npm run simulate -- --dry-run --once"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
