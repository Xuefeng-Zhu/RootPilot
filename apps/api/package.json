{
  "name": "@rootpilot/api",
  "version": "0.1.0",
  "private": true,
  "description": "RootPilot ingestion and query API",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "start": "node dist/index.js",
    "db:init": "tsx src/scripts/db-init.ts",
    "db:migrate": "tsx src/scripts/db-migrate.ts",
    "seed": "tsx src/scripts/seed.ts",
    "graph:build": "tsx src/scripts/correlation-refresh.ts --mode graph",
    "error-groups:build": "tsx src/scripts/correlation-refresh.ts --mode error-groups",
    "deployments:analyze": "tsx src/scripts/correlation-refresh.ts --mode deployments",
    "correlations:refresh": "tsx src/scripts/correlation-refresh.ts --mode all"
  },
  "dependencies": {
    "@clickhouse/client": "^1.1.0",
    "fastify": "^4.28.0",
    "pg": "^8.12.0",
    "uuid": "^9.0.0",
    "@rootpilot/shared": "*"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "fast-check": "^3.19.0"
  }
}
